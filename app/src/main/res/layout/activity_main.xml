<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:keepScreenOn="true"
    android:paddingLeft="40dp"
    android:paddingTop="26dp"
    android:paddingRight="40dp"
    android:paddingBottom="20dp">

    <LinearLayout
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@+id/footerLayout"
        android:layout_marginBottom="18dp"
        android:layout_centerInParent="true"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <FrameLayout
            android:layout_width="446dp"
            android:layout_height="446dp"
            android:background="@drawable/bg_cover_frame">

            <ImageView
                android:id="@+id/coverImageView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop" />

            <TextView
                android:id="@+id/coverPlaceholderText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="@string/no_cover"
                android:textColor="@color/subtle_text"
                android:textSize="24sp"
                android:textStyle="bold" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="40dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <TextView
                android:id="@+id/titleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="2"
                android:text="@string/waiting_title"
                android:textColor="@color/title_text"
                android:textSize="52sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/artistText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="2"
                android:textColor="@color/body_text"
                android:textSize="32sp" />

            <TextView
                android:id="@+id/albumText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="2"
                android:textColor="@color/subtle_text"
                android:textSize="24sp" />

            <TextView
                android:id="@+id/stateText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:includeFontPadding="false"
                android:textColor="@color/state_text"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/footerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/controlsLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/previousButton"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:background="@drawable/bg_control_icon"
                android:contentDescription="@string/control_previous_desc"
                android:padding="11dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_control_previous" />

            <ImageButton
                android:id="@+id/playPauseButton"
                android:layout_width="82dp"
                android:layout_height="82dp"
                android:layout_marginLeft="18dp"
                android:layout_marginRight="18dp"
                android:background="@drawable/bg_control_circle"
                android:contentDescription="@string/control_pause_desc"
                android:padding="19dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_control_pause" />

            <ImageButton
                android:id="@+id/nextButton"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:background="@drawable/bg_control_icon"
                android:contentDescription="@string/control_next_desc"
                android:padding="11dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_control_next" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/progressLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/progressStartText"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:textColor="@color/control_time_text"
                android:textSize="17sp" />

            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="8dp"
                android:layout_marginLeft="14dp"
                android:layout_marginRight="14dp"
                android:layout_weight="1"
                android:indeterminate="false"
                android:progressDrawable="@drawable/progress_horizontal" />

            <TextView
                android:id="@+id/progressEndText"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:gravity="right"
                android:includeFontPadding="false"
                android:textColor="@color/control_time_text"
                android:textSize="17sp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/statusOverlayText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/footerLayout"
        android:layout_alignParentRight="true"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_waiting_badge"
        android:gravity="right"
        android:paddingLeft="12dp"
        android:paddingTop="8dp"
        android:paddingRight="12dp"
        android:paddingBottom="8dp"
        android:text="@string/waiting_overlay"
        android:textColor="@color/overlay_text"
        android:textSize="14sp"
        android:visibility="gone" />
</RelativeLayout>
